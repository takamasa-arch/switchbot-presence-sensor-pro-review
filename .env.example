# 何を: WordPress API投稿で使う環境変数の雛形。なぜ: 実キーをコミットせずに設定共有するため。

# Required
WP_BASE="https://simple-was-best.com/wp-json/wp/v2"
WP_USER="YOUR_WP_USERNAME"
WP_APP_PASS="xxxx xxxx xxxx xxxx xxxx xxxx"

# Optional
POST_TITLE="【実機レビュー】SwitchBot人感センサーPro"
POST_SLUG="switchbot-presence-sensor-pro-review"
ARTICLE_MD="switchbot-presence-sensor-pro-review.md"
FEATURED_IMAGE="switchbot-presence-sensor-pro-06.jpg"

# Optional(JSON): H2見出しと差し込み画像ファイルの対応
# 例: IMAGE_INSERT_MAP='{"なぜ注目したか: 書斎で集中していると照明が消えることがあった":"switchbot-presence-sensor-pro-01.jpg"}'
IMAGE_INSERT_MAP=""

# Optional(JSON): 画像ファイル名とalt文言の対応
# 例: IMAGE_ALT_MAP='{"switchbot-presence-sensor-pro-01.jpg":"書斎での利用イメージ"}'
IMAGE_ALT_MAP=""
